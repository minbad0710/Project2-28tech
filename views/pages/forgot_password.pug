extends ../layouts/account.pug


block title
  title Quên mật khẩu

block main 
  .form-account
    h1.inner-title Quên mật khẩu
    p.inner-desc Vui lòng nhập email để tiếp tục

    form.inner-form(action= "")
      .inner-group
        label.inner-label(for = 'email') Email
        input(
          type = 'email'
          id = 'email'
          name = 'email'
          placeholder = 'Ví dụ: levana@gmail.com'
          class = 'inner-control'
        )

      button.inner-button Gửi mã OTP

    .inner-more
      span Bạn đã nhớ mật khẩu?    
      a(href = '#') Đăng nhập