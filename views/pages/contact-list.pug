extends ../layouts/default.pug
include ../mixins/checkbox.pug
block title 
  title Thông tin liên hệ
block main
  h1.box-title Thông tin liên hệ
  //Section 4
  .section-4 
    .inner-wrap 
      .inner-item 
        <i class="fa-solid fa-filter"></i> Bộ lọc 
      .inner-item 
        input(type = 'date')
        span  - 
        input(type = 'date')

      .inner-item.inner-reset 
        <i class="fa-solid fa-rotate-left"></i> Xóa bộ lọc

  //End section 4

  //Section 5
  .section-5 
    form.inner-status(action="")
      .inner-item 
        select
          option(value = '') -- Hành động --
          option(value = '') Hoạt động
          option(value = '') Tạm dừng
          option(value = '') Xóa
      
      .inner-item 
        button Áp dụng
      
    form.inner-search(action="")
      button <i class="fa-solid fa-magnifying-glass"></i>
      input(type = 'text' placeholder = 'Tìm kiếm') 

  // End section 5

  //Section 6
  .section-6 
    .inner-table
      table 
        thead 
          tr 
            th 
              +checkbox-30('', '')
            th Email
            th Ngày tạo
            th Hành động
        
        tbody 
          tr
            td 
              +checkbox-30('', '')
            td levana@gmail.com
            td 16:40 - 12/12/2024
            td
              .inner-action
                a(href = '#' class = 'inner-remove') <i class="fa-regular fa-trash-can"></i>
        

  //End section 6


  //Section 7

  .section-7
    .inner-text Hiển thị 1 - 9 của 78
    select 
      option(value = '') Trang 1
      option(value = '') Trang 2
      option(value = '') Trang 3

  //End section 7

